# Backend environment variables — copy to .env and fill in real values

# MongoDB
MONGO_URL="mongodb://localhost:27017"
DB_NAME="apartment_maintenance"

# Auth
JWT_SECRET="generate-a-random-64-character-hex-string-here"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-on-first-deploy"

# CORS
CORS_ORIGINS="*"

# Web Push (generate VAPID keys: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); ...")
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_PEM=""
VAPID_CONTACT_EMAIL="admin@example.com"

# SLA configuration (hours)
SLA_HOURS="72"
